# MongoDB
MONGODB_URI=mongodb://localhost:27017/climb-crux

# Server
PORT=4000
# http://localhost:5173 for local dev
# https://climb-crux-frontend.vercel.app for production
FRONTEND_URL=https://climb-crux-frontend.vercel.app

# Auth (JWT)
JWT_SECRET=change-this-to-a-random-string

# Gmail SMTP (email) — generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_EMAIL=climbcruxpakistan@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Where to send admin booking notifications
NOTIFICATION_EMAIL=climbcruxpakistan@gmail.com

# DNS servers (optional, comma-separated)
# DNS_SERVERS=8.8.8.8,1.1.1.1
