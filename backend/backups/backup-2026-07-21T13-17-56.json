  "about": [
    {
      "_id": "6a5f627323c53b566a0e83bd",
      "description": "Climb Crux started with a simple idea: the limestone of Margalla Hills shouldn't be reserved for people who already know how to climb. We run sessions for the person picking up a harness for the first time, and for the one training toward their hardest send yet.",
      "safetyItems": [
        {
          "h": "Pre-climb briefing",
          "p": "Every session opens with a full gear check and safety walkthrough before anyone touches rock."
        },
        {
          "h": "Certified belay technique",
          "p": "All instructors are trained and certified in belay systems, knots, and anchor building."
        },
        {
          "h": "Redundant anchor systems",
          "p": "Routes are set with backup anchor points as standard practice, not an upgrade."
        },
        {
          "h": "First-aid ready",
          "p": "Instructors carry first-aid kits and are trained in on-site response and evacuation procedure."
        }
      ],
      "createdAt": "2026-07-21T12:13:39.696Z",
      "updatedAt": "2026-07-21T12:13:39.696Z",
      "__v": 0
    }
  ],
